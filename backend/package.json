{
  "name": "geoloom-agent-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:dependency-service": "tsx watch src/dev/realDependencyService.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "start:dependency-service": "node dist/src/dev/realDependencyService.js",
    "start:direct": "tsx src/server.ts",
    "test": "vitest run",
    "test:e2e:phase8-3": "vitest run tests/integration/e2e/phase8_3_regression.spec.ts",
    "test:smoke:minimax": "vitest run tests/smoke/minimaxPhase8_3.smoke.spec.ts",
    "test:smoke:dependencies": "vitest run tests/smoke/remoteDependenciesPhase8_3.smoke.spec.ts",
    "test:smoke:phase8-3": "vitest run tests/smoke/minimaxPhase8_3.smoke.spec.ts tests/smoke/remoteDependenciesPhase8_3.smoke.spec.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@types/cheerio": "^0.22.35",
    "cheerio": "^1.2.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.3.0",
    "pg": "^8.16.3",
    "pgsql-ast-parser": "^12.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
