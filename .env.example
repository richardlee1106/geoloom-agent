VITE_GEOLOOM_API_BASE=http://127.0.0.1:3210

# Multi Search Engine 配置
MULTI_SEARCH_TIMEOUT_MS=10000
MULTI_SEARCH_MAX_ENGINES=3

# Tavily 搜索配置（可选，作为后备搜索引擎）
TAVILY_API_KEY=
TAVILY_TIMEOUT_MS=15000

# Jina 在线 API 配置（Embedding + Reranker）
JINA_API_KEY=your_jina_api_key_here
JINA_EMBED_URL=https://api.jina.ai/v1
JINA_RERANK_URL=https://api.jina.ai/v1
JINA_EMBEDDING_MODEL=jina-embeddings-v5-text-small
JINA_RERANKER_MODEL=jina-reranker-v3
